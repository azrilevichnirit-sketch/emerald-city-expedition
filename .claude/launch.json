{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Emerald Static Server",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd /d C:\\emerald && python -m http.server 3000"],
      "port": 3000
    },
    {
      "name": "Static File Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["C:\\emerald\\pipeline\\_serve_emerald.py"],
      "port": 3000
    },
    {
      "name": "Static File Server (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "--port", "3000", "--no-clipboard"],
      "port": 3000
    }
  ]
}
